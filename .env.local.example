# Required for barcode lookup — app will fail to start without these.
# UpcItemDB (first in chain) uses a free trial endpoint and needs no key.
# Sign up at https://go-upc.com/dashboard (free: 100 req/month)
NEXT_PUBLIC_GO_UPC_API_KEY=your_go_upc_key_here
# Sign up at https://upcdatabase.org/api (free: 100 req/day)
NEXT_PUBLIC_UPCDATABASE_API_KEY=your_upcdatabase_key_here
